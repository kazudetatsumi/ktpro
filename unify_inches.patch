+def _build_axes_in_sf_inches(
+    sf,
+    # 余白 [in]
+    left_in=0.60, right_in=1.37, top_in=0.30, bottom_in=0.40,
+    # パネル幅 [in]
+    panel_w_in=3.00,
+    # 各段の高さ [in]
+    h1_in=1.20, h2_in=1.20, h3_in=1.20, h4_in=1.20,
+    # 段間ギャップ [in]
+    s12_in=0.00, s23_in=0.00, s34_in=0.00,
+):
+    """SubFigure 上に、インチ絶対寸法で 4 段を配置する。"""
+    fig = sf.figure
+    fig.canvas.draw()
+    Wf_in, Hf_in = fig.get_size_inches()
+    sf_pos = sf.get_position()  # figure 座標
+
+    def figrect_to_sf(rect):
+        x0, y0, w, h = rect
+        return [
+            (x0 - sf_pos.x0)/sf_pos.width,
+            (y0 - sf_pos.y0)/sf_pos.height,
+            w/sf_pos.width,
+            h/sf_pos.height,
+        ]
+
+    # 横方向（インチ → Figure座標）
+    x0_fig = sf_pos.x0 + left_in / Wf_in
+    x1_fig = sf_pos.x1 - right_in / Wf_in
+    w_fig  = min(panel_w_in / Wf_in, max(0.0, x1_fig - x0_fig))
+
+    # 縦方向の可用域（SubFigure 内）
+    y0_avail = sf_pos.y0 + bottom_in / Hf_in
+    y1_avail = sf_pos.y1 - top_in / Hf_in
+
+    # 4 段の絶対高さとギャップ（インチ → Figure座標）
+    h1_fig = h1_in / Hf_in
+    h2_fig = h2_in / Hf_in
+    h3_fig = h3_in / Hf_in
+    h4_fig = h4_in / Hf_in
+    g12_fig = s12_in / Hf_in
+    g23_fig = s23_in / Hf_in
+    g34_fig = s34_in / Hf_in
+    total_h = h1_fig + g12_fig + h2_fig + g23_fig + h3_fig + g34_fig + h4_fig
